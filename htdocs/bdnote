DROP DATABASE IF EXISTS bdnote;

CREATE DATABASE bdnote
    DEFAULT CHARACTER SET utf8mb4
    DEFAULT COLLATE utf8mb4_unicode_ci;

USE bdnote;

CREATE TABLE users(
	user_id INT AUTO_INCREMENT,
	nome VARCHAR(30) NOT NULL,
	bio TEXT ,
	email VARCHAR(50) NOT NULL,
	login DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
	cdate DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
	UNIQUE (email),	
	PRIMARY KEY (user_id)
);



CREATE TABLE reading_history(
	user_id INT,
	book_id INT,
	date DATETIME,
	PRIMARY KEY (user_id, book_id, date)
);


CREATE TABLE book(
	book_id INT AUTO_INCREMENT,
	book_users_id INT,
	comment_id INT,
	autor VARCHAR(20), 	
	title VARCHAR(30),
	description TEXT,
	cover text,
	rating double,
	last_up DATETIME NOT NULL,
	PRIMARY KEY (book_id)
);

CREATE TABLE book_genre(
	genre_id INT,
	book_id INT,
	PRIMARY KEY (genre_id, book_id)
);

CREATE TABLE book_event(
	event_id INT,
	book_id INT,
	PRIMARY KEY (event_id, book_id)
);

CREATE TABLE event(
	event_id INT,
	events TEXT NOT NULL,
	PRIMARY KEY(event_id)	
);

CREATE TABLE genre(
	genre_id INT,
	genres TEXT NOT NULL,
	PRIMARY KEY (genre_id)
);
CREATE TABLE chapter(
	chapter_id INT AUTO_INCREMENT,
	chapter_book_id INT,
	comment_id INT,
	title VARCHAR(50),
	content VARCHAR(200),
	PRIMARY KEY (chapter_id)
);

CREATE TABLE note(
	note_id INT AUTO_INCREMENT,
	note_book_id INT,
	note_users_id INT,
	note_chapter_id INT,
	title VARCHAR(30),
	content TEXT,
	rating DOUBLE,
	image TEXT NOT NULL,
	PRIMARY KEY (note_id)
);


CREATE TABLE location (
    	location_id INT NOT NULL AUTO_INCREMENT,
	location_note_id INT,
   	latitude DOUBLE,
    	longitude DOUBLE,
   	PRIMARY KEY (location_id)
);

CREATE TABLE comment (
	comment_id INT AUTO_INCREMENT,
	comment_book_id INT,
	comment_chapter_id INT,
	comment_users_id INT,
	content TEXT NOT NULL,
	cdate DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
	PRIMARY KEY (comment_id)
);

-- Foreign Keys

alter table book 
add constraint book_fk_users
foreign key (book_users_id) references users(user_id) 
ON DELETE NO ACTION ON UPDATE NO ACTION;

alter table chapter 
add constraint chapter_fk_book
foreign key (chapter_book_id) references book(book_id) 
ON DELETE NO ACTION ON UPDATE NO ACTION;

alter table note
add constraint note_fk_chapter
foreign key (note_chapter_id) references chapter(chapter_id) 
ON DELETE NO ACTION ON UPDATE NO ACTION;

alter table note
add constraint note_fk_users
foreign key (note_users_id) references users(user_id)
ON DELETE NO ACTION ON UPDATE NO ACTION;

alter table note 
add constraint note_fk_book
foreign key (note_book_id) references book(book_id)
ON DELETE NO ACTION ON UPDATE NO ACTION; 

alter table location
add constraint location_fk_note
foreign key(location_note_id) references note(note_id)
ON DELETE NO ACTION ON UPDATE NO ACTION;

alter table comment
add constraint comment_fk_book
foreign key (comment_book_id) references book(book_id)
ON DELETE NO ACTION ON UPDATE NO ACTION;

alter table comment
add constraint comment_fk_users
foreign key (comment_users_id) references users(user_id)
ON DELETE NO ACTION ON UPDATE NO ACTION;

alter table comment
add constraint comment_fk_chapter
foreign key (comment_chapter_id) references chapter(chapter_id)
ON DELETE NO ACTION ON UPDATE NO ACTION;


CREATE INDEX idx_note_many ON note(note_book_id, note_users_id, note_chapter_id);
CREATE INDEX idx_comment_many ON comment(comment_book_id, comment_chapter_id, comment_users_id);
CREATE INDEX idx_history_many ON reading_history(user_id, book_id);
CREATE INDEX idx_book_genre ON book_genre(genre_id, book_id);
CREATE INDEX idx_book_event ON book_event(event_id, book_id);